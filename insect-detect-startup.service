[Unit]
Description=Insect Detect Startup Service
Documentation=https://maxsitt.github.io/insect-detect-docs/
Wants=network-online.target
After=network.target network-online.target NetworkManager.service

[Service]
Type=oneshot
# Default Raspberry Pi OS username - change if using a different user
User=pi
Group=pi
WorkingDirectory=/home/pi/insect-detect
ExecStart=/home/pi/.local/bin/uv run startup
Environment=HOME=/home/pi
RemainAfterExit=yes
TimeoutStartSec=600
TimeoutStopSec=30
StandardOutput=journal
StandardError=journal
SyslogIdentifier=insect-detect-startup

[Install]
WantedBy=multi-user.target